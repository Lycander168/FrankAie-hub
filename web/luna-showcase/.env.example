# 複製成 .env.local 並填入你的 SHOPLINE 憑證，即可從 mock 切換成真實商品資料。
# 留空則自動使用 mock（src/data/luna.mock.json）。

# 店家網域（Storefront API 用）
VITE_SHOPLINE_DOMAIN=your-store.myshopline.com

# Storefront Access Token（guest 讀取商品只需這個；不要放 Admin secret）
VITE_SHOPLINE_TOKEN=

# API 版本（可省略，預設 v20240301）
VITE_SHOPLINE_API_VER=v20240301
